# Local Netlify
.netlify/

# Dependencies
node_modules/

# IMPORTANT: Do NOT ignore package-lock.json, yarn.lock, or pnpm-lock.yaml.
# Vercel / Netlify / npm ci rely on the lockfile next to each package.json.

# Environment (keep tracked examples)
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editors / swap
.idea/
.vscode/*.local
*.swp
*~

# Cursor / Claude local settings
.claude/

# Temp / scratch (Illustrator, editors)
*.tmp
.tmp/
**/~*
*~*.tmp

# Build output
dist/
coverage/
.nyc_output/
