{
  "name": "t-shaped-email-functions",
  "private": true,
  "version": "0.1.0",
  "description": "Netlify functions for T-shaped tool email delivery",
  "scripts": {
    "dev": "netlify dev",
    "dev:shape": "cd t-shaped && npm run dev",
    "build:shape": "cd t-shaped && npm run build",
    "serve": "npx serve t-shaped/dist",
    "build:css": "tailwindcss -i ./t-shaped/styles.css -o ./t-shaped/styles.out.css --minify",
    "watch:css": "tailwindcss -i ./t-shaped/styles.css -o ./t-shaped/styles.out.css --watch"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "archiver": "^7.0.1",
    "jpeg-js": "^0.4.4",
    "nodemailer": "^6.9.16",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4"
  }
}
